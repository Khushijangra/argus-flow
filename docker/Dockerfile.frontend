FROM node:18-alpine AS builder

WORKDIR /app

# Install dependencies
COPY digital-twin-frontend/package.json digital-twin-frontend/package-lock.json ./
RUN npm ci

# Copy source
COPY digital-twin-frontend/ .

# Build for production
RUN npm run build

# Use lightweight web server
FROM nginx:alpine
COPY --from=builder /app/build /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
